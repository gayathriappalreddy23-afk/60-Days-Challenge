#Abstract Method
from abc import ABC, abstractmethod

class Shape(ABC):

    @abstractmethod
    def area(self):
        pass

class Circle(Shape):

    def area(self):
        return 3.14 * 5 * 5

c = Circle()
print("\n\n",c.area())

#Practice
from abc import ABC,abstractmethod
class person:
    def __init__(self,name,age):
        self.name=name
        self.age=age
    def introduce(self):
        return f"Hello, my name is {self.name} and I am {self.age} years old."
class Employee(person,ABC):
    def __init__(self,name,age,salary):
        super().__init__(name,age)
        self.__salary=salary
    def calculate_salary(self):
        pass
    def get_salary(self):
        return self.__salary
    def introduce(self):
        parent_intro=super().introduce()
        return f"{parent_intro} I am a Employee."
class Manager(Employee):
    def __init__(self,name,age,salary,bonus):
        super().__init__(name,age,salary)
        self.bonus=bonus
    def calculate_salary(self):
        return self.get_salary()+self.bonus
    def introduce(self):
        parent_intro=super().introduce()
        return f"{parent_intro} Specifically, I work as a Manager."
if __name__ == "__main__":
    # Requirement: Print MRO (Method Resolution Order)
    print("--- Method Resolution Order (MRO) ---")
    print([cls.__name__ for cls in Manager.__mro__])
    print()

    print("--- Object Instantiation & Method Outputs ---")
    # Instantiating the Manager object
    manager = Manager(name="Alice Smith", age=42, salary=80000, bonus=15000)

    # Displaying overridden method output
    print(manager.introduce())

    # Displaying calculate_salary output
    print(f"Total calculated salary: ${manager.calculate_salary():,}")
    
